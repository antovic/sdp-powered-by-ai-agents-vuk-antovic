{
  "name": "tdd-bdd-agent",
  "description": "TDD/BDD agent — implements kata features using strict RED-GREEN-REFACTOR discipline, one test at a time",
  "prompt": "file://./tdd-bdd-prompt.md",
  "tools": [
    "fs_read",
    "fs_write",
    "shell"
  ],
  "allowedTools": [
    "fs_read",
    "fs_write",
    "shell"
  ],
  "resources": [
    "file://docs/user-stories/**/*.md"
  ],
  "hooks": {
    "postToolUse": [
      {
        "matcher": "fs_write",
        "command": "docker run --rm -v \"$(pwd)\":/app kata-tests"
      }
    ]
  }
}
